<Window x:Class="PCleaner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PCleaner.ViewModels"
        mc:Ignorable="d"
        Title="PCleaner - 专家级存储分析与清理" Height="800" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#F0F2F5">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <vm:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <vm:CategoryToColorConverter x:Key="CategoryToColorConverter" />
        <vm:CategoryToTextConverter x:Key="CategoryToTextConverter" />

        <!-- Tier Pill Style -->
        <Style x:Key="TierPillStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <!-- Group Header Style -->
        <Style x:Key="GroupHeaderStyle" TargetType="{x:Type GroupItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GroupItem}">
                        <StackPanel Margin="0,0,0,15">
                            <Border Background="#E1E5EB" Padding="15,8" CornerRadius="4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name, Converter={StaticResource CategoryToTextConverter}}" FontWeight="Bold" FontSize="14" Foreground="#2C3E50" />
                                    <TextBlock Text="{Binding ItemCount, StringLength=' ({0} 项)'}" VerticalAlignment="Center" Foreground="#7F8C8D" Margin="5,0,0,0" />
                                </StackPanel>
                            </Border>
                            <ItemsPresenter />
                        </StackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header -->
            <RowDefinition Height="*" />    <!-- Content Scrollable -->
            <RowDefinition Height="Auto" /> <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="20,15">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="PCleaner" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
                    <Border Background="#34495E" CornerRadius="4" Padding="5,2" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="专业版" Foreground="#BDC3C7" FontSize="10" />
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <CheckBox Content="使用回收站" IsChecked="{Binding UseRecycleBin}" Foreground="#ECF0F1" VerticalAlignment="Center" Margin="0,0,20,0" />
                    <Button Content="开始全面诊断" Command="{Binding StartScanCommand}" IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBooleanConverter}}"
                            Padding="25,10" Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="Bold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel>
                
                <!-- Disk Overview Card -->
                <Border Background="White" CornerRadius="8" Padding="25" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1" />
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="磁盘状态" FontSize="14" Foreground="#7F8C8D" Margin="0,0,0,5" />
                            <TextBlock Text="{Binding SelectedDisk.Name}" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" />
                            <TextBlock Text="主系统盘" FontSize="12" Foreground="#95A5A6" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="20,0,0,0">
                            <DockPanel LastChildFill="False" Margin="0,0,0,10">
                                <TextBlock DockPanel.Dock="Left" Text="存储占用概览" FontWeight="Bold" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <TextBlock Text="已用 " Foreground="#7F8C8D" />
                                    <TextBlock Text="{Binding SelectedDisk.UsedSpaceReadable}" FontWeight="Bold" />
                                    <TextBlock Text=" / " Foreground="#7F8C8D" />
                                    <TextBlock Text="{Binding SelectedDisk.TotalSpaceReadable}" Foreground="#7F8C8D" />
                                </StackPanel>
                            </DockPanel>
                            
                            <Grid Height="24" Margin="0,0,0,15">
                                <ProgressBar Value="{Binding SelectedDisk.UsedSpace, Mode=OneWay}" Maximum="{Binding SelectedDisk.TotalSpace, Mode=OneWay}" Foreground="#BDC3C7" Background="#ECF0F1" BorderThickness="0" />
                                <ProgressBar Value="{Binding TotalCleanableSize, Mode=OneWay}" Maximum="{Binding SelectedDisk.TotalSpace, Mode=OneWay}" Foreground="#2ECC71" Background="Transparent" BorderThickness="0" />
                                <TextBlock Text="{Binding SelectedDisk.FreeSpaceReadable, StringLength='可用 {0}'}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="10" Foreground="#2C3E50" FontWeight="Bold" />
                            </Grid>

                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource TierPillStyle}" Background="#2ECC71">
                                    <TextBlock Text="{Binding GreenSizeText, StringLength='可自动清理: {0}'}" Foreground="White" FontSize="11" />
                                </Border>
                                <Border Style="{StaticResource TierPillStyle}" Background="#F39C12">
                                    <TextBlock Text="{Binding YellowSizeText, StringLength='需人工判断: {0}'}" Foreground="White" FontSize="11" />
                                </Border>
                                <Border Style="{StaticResource TierPillStyle}" Background="#E74C3C">
                                    <TextBlock Text="{Binding RedSizeText, StringLength='建议不手删: {0}'}" Foreground="White" FontSize="11" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Top 5 Heavy Hitters -->
                <TextBlock Text="占用排行 Top 5" FontSize="18" FontWeight="Bold" Margin="0,10,0,10" Foreground="#2C3E50" />
                <ItemsControl ItemsSource="{Binding TopItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="5" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="6" Margin="0,0,10,20" Padding="15">
                                <StackPanel>
                                    <Ellipse Width="8" Height="8" Fill="{Binding Category, Converter={StaticResource CategoryToColorConverter}}" HorizontalAlignment="Left" Margin="0,0,0,5" />
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding SizeReadable}" FontSize="16" Foreground="#E74C3C" FontWeight="Bold" Margin="0,5" />
                                    <Button Content="定位" Background="Transparent" BorderThickness="1" BorderBrush="#DCDFE6" FontSize="10" Padding="5,2" 
                                            Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                            CommandParameter="{Binding Path}" Cursor="Hand" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Actionable Tiered Sections -->
                <TextBlock Text="执行建议" FontSize="18" FontWeight="Bold" Margin="0,10,0,10" Foreground="#2C3E50" />
                <ListView ItemsSource="{Binding ScanItemsView}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.GroupStyle>
                        <GroupStyle ContainerStyle="{StaticResource GroupHeaderStyle}" />
                    </ListView.GroupStyle>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="White" />
                            <Setter Property="Margin" Value="0,0,0,10" />
                            <Setter Property="Padding" Value="15" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                
                                <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Top" Margin="0,5,15,0" />
                                
                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" />
                                        <TextBlock Text="{Binding SizeReadable}" Margin="15,0,0,0" VerticalAlignment="Bottom" Foreground="#E74C3C" FontWeight="Bold" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Foreground="#7F8C8D" FontSize="13" LineHeight="20" />
                                    <TextBlock Text="{Binding RiskHint}" Foreground="#E67E22" FontSize="12" Margin="0,5,0,0" FontStyle="Italic" Visibility="{Binding RiskHint, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    <TextBlock Text="{Binding Path}" Foreground="#95A5A6" FontSize="11" Margin="0,8,0,0" />
                                </StackPanel>
                                
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="20,0,0,0">
                                    <Button Content="在资源管理器打开" Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                            CommandParameter="{Binding Path}" Background="White" BorderBrush="#DCDFE6" Padding="15,8" Margin="0,0,0,5" Cursor="Hand" />
                                    <Button Content="删除该项" Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                            CommandParameter="{Binding}" Background="#FDF2F2" BorderBrush="#F8D7DA" Foreground="#DC3545" Padding="15,8" Cursor="Hand" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Long Term Suggestions -->
                <Border Background="#EBFAEF" BorderBrush="#C3E6CB" BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,20,0,40">
                    <StackPanel>
                        <TextBlock Text="长期优化建议" FontSize="16" FontWeight="Bold" Foreground="#155724" Margin="0,0,0,10" />
                        <ItemsControl ItemsSource="{Binding LongTermSuggestions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#155724" Margin="0,0,0,5" FontSize="13" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                
            </StackPanel>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="White" BorderBrush="#DCDFE6" BorderThickness="0,1,0,0" Padding="20,10">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <ProgressBar IsIndeterminate="True" Width="100" Height="4" VerticalAlignment="Center" Margin="0,0,15,0" Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="#7F8C8D" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="选中可释放: " VerticalAlignment="Center" />
                    <TextBlock Text="{Binding TotalCleanableSizeReadable}" Foreground="#27AE60" FontWeight="Bold" FontSize="18" VerticalAlignment="Center" Margin="0,0,20,0" />
                    <Button Content="立即执行安全清理" Command="{Binding CleanSelectedCommand}" Padding="30,12" Background="#27AE60" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
