<Window x:Class="PCleaner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PCleaner.ViewModels"
        mc:Ignorable="d"
        Title="PCleaner - 专业存储清理工具" Height="650" Width="900"
        WindowStartupLocation="CenterScreen" Background="#F5F6F7">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <vm:InverseBooleanConverter x:Key="InverseBooleanConverter" />
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header -->
            <RowDefinition Height="Auto" /> <!-- Disk Overview -->
            <RowDefinition Height="*" />    <!-- Content List -->
            <RowDefinition Height="Auto" /> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="PCleaner" FontSize="28" FontWeight="Bold" Foreground="#333" VerticalAlignment="Center" />
                <TextBlock Text="v1.0" Margin="10,0,0,0" VerticalAlignment="Bottom" Foreground="#999" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <CheckBox Content="使用回收站" IsChecked="{Binding UseRecycleBin}" VerticalAlignment="Center" Margin="0,0,20,0" />
                <Button Content="开始扫描" Command="{Binding StartScanCommand}" IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBooleanConverter}}"
                        Padding="20,8" Background="#0078D4" Foreground="White" BorderThickness="0" Cursor="Hand" />
            </StackPanel>
        </DockPanel>

        <!-- Disk Overview -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="磁盘概览 (C:)" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,20,0" />
                <StackPanel Grid.Column="1">
                    <Grid>
                        <ProgressBar Height="20" Value="{Binding SelectedDisk.UsedSpace, Mode=OneWay}" Maximum="{Binding SelectedDisk.TotalSpace, Mode=OneWay}" Foreground="#0078D4" Background="#E1E1E1" />
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11">
                            <Run Text="{Binding SelectedDisk.UsedSpaceReadable, Mode=OneWay}" />
                            <Run Text=" / " />
                            <Run Text="{Binding SelectedDisk.TotalSpaceReadable, Mode=OneWay}" />
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content List -->
        <Border Grid.Row="2" Background="White" CornerRadius="8">
            <Grid>
                <ListView ItemsSource="{Binding ScanItems}" BorderThickness="0" Margin="5">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="选择" Width="50">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}" HorizontalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="名称" DisplayMemberBinding="{Binding Name}" Width="120" />
                            <GridViewColumn Header="路径" DisplayMemberBinding="{Binding Path}" Width="350" />
                            <GridViewColumn Header="大小" DisplayMemberBinding="{Binding SizeReadable}" Width="100" />
                            <GridViewColumn Header="建议" DisplayMemberBinding="{Binding Description}" Width="150" />
                            <GridViewColumn Header="操作" Width="100">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="📁" ToolTip="打开文件夹" Background="Transparent" BorderThickness="0" 
                                                    Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Path}" Margin="0,0,5,0" />
                                            <Button Content="🗑️" ToolTip="删除" Background="Transparent" BorderThickness="0" Foreground="Red"
                                                    Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- Loading Overlay -->
                <Border Background="#80FFFFFF" Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel VerticalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="200" Height="4" Margin="0,0,0,10" />
                        <TextBlock Text="{Binding StatusText}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Footer -->
        <DockPanel Grid.Row="3" Margin="0,20,0,0">
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="#666" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock VerticalAlignment="Center" Margin="0,0,20,0">
                    <Run Text="选中大小: " />
                    <Run Text="{Binding TotalCleanableSizeReadable, Mode=OneWay}" FontWeight="Bold" Foreground="#D13438" />
                </TextBlock>
                <Button Content="一键清理绿色项" Command="{Binding CleanSelectedCommand}" Padding="25,10" 
                        Background="#D13438" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="Bold" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
