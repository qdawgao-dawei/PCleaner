<Window x:Class="PCleaner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PCleaner.ViewModels"
        mc:Ignorable="d"
        Title="PCleaner - 专家级存储分析与清理" Height="800" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#F0F2F5"
        UseLayoutRounding="True" 
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <vm:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <vm:CategoryToColorConverter x:Key="CategoryToColorConverter" />
        <vm:CategoryToTextConverter x:Key="CategoryToTextConverter" />

        <!-- Tier Pill Style -->
        <Style x:Key="TierPillStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <!-- Group Header Style (Collapsible) -->
        <Style x:Key="GroupHeaderStyle" TargetType="{x:Type GroupItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GroupItem}">
                        <Expander IsExpanded="False" Margin="0,0,0,10" Background="Transparent" BorderThickness="0">
                            <Expander.Header>
                                <Border Background="#E1E5EB" Padding="12,6" CornerRadius="4" Width="{Binding RelativeSource={RelativeSource AncestorType=Expander}, Path=ActualWidth, Converter={StaticResource InverseBooleanConverter}, ConverterParameter=Offset}">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="10" Height="10" Fill="{Binding Name, Converter={StaticResource CategoryToColorConverter}}" Margin="0,0,10,0" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Name, Converter={StaticResource CategoryToTextConverter}}" FontWeight="Bold" FontSize="13" Foreground="#2C3E50" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding ItemCount, StringFormat=' ({0} 项)'}" VerticalAlignment="Center" Foreground="#7F8C8D" Margin="5,0,0,0" FontSize="12" />
                                    </StackPanel>
                                </Border>
                            </Expander.Header>
                            <ItemsPresenter />
                        </Expander>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header -->
            <RowDefinition Height="*" />    <!-- Content Scrollable -->
            <RowDefinition Height="Auto" /> <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="15,10">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <!-- Brand Icon (Vector) -->
                    <Viewbox Width="24" Height="24" Margin="0,0,10,0">
                        <Canvas Width="24" Height="24">
                            <Path Fill="#3498DB" Data="M12,2C6.47,2 2,6.47 2,12C2,17.53 6.47,22 12,22C17.53,22 22,17.53 22,12C22,6.47 17.53,2 12,2M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M15,12A3,3 0 0,1 12,15A3,3 0 0,1 9,12A3,3 0 0,1 12,9A3,3 0 0,1 15,12Z" />
                            <Path Fill="#E74C3C" Data="M7,12H9V12.12L11,10.12V10H13V10.12L15,8.12V8H17V8.12L12,13.12L7,8.12V12Z" Opacity="0.8" />
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="PCleaner" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
                    <Border Background="#34495E" CornerRadius="4" Padding="4,1" Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="专业版" Foreground="#BDC3C7" FontSize="9" />
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <CheckBox Content="使用回收站" IsChecked="{Binding UseRecycleBin}" Foreground="#ECF0F1" VerticalAlignment="Center" Margin="0,0,15,0" FontSize="12" />
                    <Button Content="开始全面诊断" Command="{Binding StartScanCommand}" IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBooleanConverter}}"
                            Padding="20,6" Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="Bold" FontSize="12">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="15">
            <StackPanel>
                
                <!-- Disk Overview Card -->
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05" />
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="磁盘状态" FontSize="12" Foreground="#7F8C8D" Margin="0,0,0,2" />
                            <TextBlock Text="{Binding SelectedDisk.Name}" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" />
                            <TextBlock Text="主系统盘" FontSize="11" Foreground="#95A5A6" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <DockPanel LastChildFill="False" Margin="0,0,0,5">
                                <TextBlock DockPanel.Dock="Left" Text="存储占用概览" FontWeight="Bold" FontSize="13" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <TextBlock Text="已用 " Foreground="#7F8C8D" FontSize="12" />
                                    <TextBlock Text="{Binding SelectedDisk.UsedSpaceReadable, Mode=OneWay}" FontWeight="Bold" FontSize="12" />
                                    <TextBlock Text=" / " Foreground="#7F8C8D" FontSize="12" />
                                    <TextBlock Text="{Binding SelectedDisk.TotalSpaceReadable, Mode=OneWay}" Foreground="#7F8C8D" FontSize="12" />
                                </StackPanel>
                            </DockPanel>
                            
                            <Grid Height="18" Margin="0,0,0,10">
                                <ProgressBar Value="{Binding SelectedDisk.UsedSpace, Mode=OneWay}" Maximum="{Binding SelectedDisk.TotalSpace, Mode=OneWay}" Foreground="#BDC3C7" Background="#ECF0F1" BorderThickness="0" />
                                <ProgressBar Value="{Binding TotalCleanableSize, Mode=OneWay}" Maximum="{Binding SelectedDisk.TotalSpace, Mode=OneWay}" Foreground="#2ECC71" Background="Transparent" BorderThickness="0" />
                                <TextBlock Text="{Binding SelectedDisk.FreeSpaceReadable, StringFormat='可用 {0}'}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="9" Foreground="#2C3E50" FontWeight="Bold" />
                            </Grid>

                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource TierPillStyle}" Background="#2ECC71" Padding="6,1">
                                    <TextBlock Text="{Binding GreenSizeText, StringFormat='可自动清理: {0}'}" Foreground="White" FontSize="10" />
                                </Border>
                                <Border Style="{StaticResource TierPillStyle}" Background="#F39C12" Padding="6,1">
                                    <TextBlock Text="{Binding YellowSizeText, StringFormat='需人工判断: {0}'}" Foreground="White" FontSize="10" />
                                </Border>
                                <Border Style="{StaticResource TierPillStyle}" Background="#E74C3C" Padding="6,1">
                                    <TextBlock Text="{Binding RedSizeText, StringFormat='建议不手删: {0}'}" Foreground="White" FontSize="10" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Top 5 Heavy Hitters -->
                <TextBlock Text="占用排行 Top 5" FontSize="18" FontWeight="Bold" Margin="0,10,0,10" Foreground="#2C3E50" />
                <ItemsControl ItemsSource="{Binding TopItems}" PreviewMouseWheel="UIElement_OnPreviewMouseWheel">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="5" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="6" Margin="0,0,10,20" Padding="15">
                                <StackPanel>
                                    <Ellipse Width="8" Height="8" Fill="{Binding Category, Converter={StaticResource CategoryToColorConverter}}" HorizontalAlignment="Left" Margin="0,0,0,5" />
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding SizeReadable}" FontSize="16" Foreground="#E74C3C" FontWeight="Bold" Margin="0,5" />
                                    <Button Content="定位" Background="Transparent" BorderThickness="1" BorderBrush="#DCDFE6" FontSize="10" Padding="5,2" 
                                            Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                            CommandParameter="{Binding Path}" Cursor="Hand" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Actionable Tiered Table -->
                <TextBlock Text="执行建议" FontSize="18" FontWeight="Bold" Margin="0,10,0,10" Foreground="#2C3E50" />
                <ListView ItemsSource="{Binding ScanItemsView}" BorderThickness="0" Background="White" ScrollViewer.HorizontalScrollBarVisibility="Disabled" PreviewMouseWheel="UIElement_OnPreviewMouseWheel" SelectionMode="Single">
                    <ListView.Resources>
                        <!-- Hide the hover/selection blue highlight to keep it clean like a table -->
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="#EBEEF5" BorderThickness="0,0,0,1" Padding="5">
                                            <GridViewRowPresenter Content="{TemplateBinding Content}" Columns="{TemplateBinding GridView.ColumnCollection}" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F5F7FA" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.Resources>
                    <ListView.GroupStyle>
                        <GroupStyle ContainerStyle="{StaticResource GroupHeaderStyle}" />
                    </ListView.GroupStyle>
                    <ListView.View>
                        <GridView>
                            <!-- Selection Column -->
                            <GridViewColumn Width="40">
                                <GridViewColumn.Header>
                                    <TextBlock Text="选" HorizontalAlignment="Center" />
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- Name Column -->
                            <GridViewColumn Header="占用项目" Width="140">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Fill="{Binding Category, Converter={StaticResource CategoryToColorConverter}}" Margin="0,0,8,0" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- Size Column -->
                            <GridViewColumn Header="体量" Width="90">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SizeReadable}" Foreground="#E74C3C" FontWeight="Bold" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- Description Column -->
                            <GridViewColumn Header="诊断说明" Width="480">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,2">
                                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="12" Foreground="#606266" />
                                            <TextBlock Text="{Binding RiskHint}" Foreground="#E67E22" FontSize="11" FontStyle="Italic" Margin="0,2,0,0" Visibility="{Binding RiskHint, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- Action Column -->
                            <GridViewColumn Header="快捷操作" Width="180">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="定位" Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                    CommandParameter="{Binding Path}" Background="White" BorderBrush="#DCDFE6" Padding="10,4" Margin="0,0,5,0" FontSize="11" Cursor="Hand" />
                                            <Button Content="删除" Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                    CommandParameter="{Binding}" Background="#FDF2F2" BorderBrush="#F8D7DA" Foreground="#DC3545" Padding="10,4" FontSize="11" Cursor="Hand" />
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- Long Term Suggestions -->
                <Border Background="#EBFAEF" BorderBrush="#C3E6CB" BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,20,0,40">
                    <StackPanel>
                        <TextBlock Text="长期优化建议" FontSize="16" FontWeight="Bold" Foreground="#155724" Margin="0,0,0,10" />
                        <ItemsControl ItemsSource="{Binding LongTermSuggestions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#155724" Margin="0,0,0,5" FontSize="13" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                
            </StackPanel>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="White" BorderBrush="#DCDFE6" BorderThickness="0,1,0,0" Padding="20,10">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <ProgressBar IsIndeterminate="True" Width="100" Height="4" VerticalAlignment="Center" Margin="0,0,15,0" Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="#7F8C8D" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="选中可释放: " VerticalAlignment="Center" />
                    <TextBlock Text="{Binding TotalCleanableSizeReadable}" Foreground="#27AE60" FontWeight="Bold" FontSize="18" VerticalAlignment="Center" Margin="0,0,20,0" />
                    <Button Content="立即执行安全清理" Command="{Binding CleanSelectedCommand}" Padding="30,12" Background="#27AE60" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
